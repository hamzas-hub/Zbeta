// ============================================
// AUDIO SYSTEM - Lightweight Web Audio API
// ============================================
class AudioSystem {
    constructor() {
        this.ctx = null;
        this.initialized = false;
        this.masterGain = null;
    }

    init() {
        if (this.initialized) return;
        try {
            this.ctx = new (window.AudioContext || window.webkitAudioContext)();
            this.masterGain = this.ctx.createGain();
            this.masterGain.gain.value = 0.3;
            this.masterGain.connect(this.ctx.destination);
            this.initialized = true;
        } catch (e) {
            console.warn('Audio not supported');
        }
    }

    // Generate tones using oscillators
    playTone(freq, duration, type = 'sine', volume = 0.3) {
        if (!this.initialized || !this.ctx) return;
        const osc = this.ctx.createOscillator();
        const gain = this.ctx.createGain();
        osc.type = type;
        osc.frequency.setValueAtTime(freq, this.ctx.currentTime);
        gain.gain.setValueAtTime(volume, this.ctx.currentTime);
        gain.gain.exponentialRampToValueAtTime(0.001, this.ctx.currentTime + duration);
        osc.connect(gain);
        gain.connect(this.masterGain);
        osc.start();
        osc.stop(this.ctx.currentTime + duration);
    }

    // Game Start Sound - ascending arpeggio
    playGameStart() {
        if (!this.initialized) this.init();
        const notes = [261.63, 329.63, 392.00, 523.25];
        notes.forEach((freq, i) => {
            setTimeout(() => this.playTone(freq, 0.3, 'sine', 0.2), i * 100);
        });
    }

    // Button Click - short blip
    playClick() {
        if (!this.initialized) this.init();
        this.playTone(800, 0.08, 'square', 0.1);
    }

    // Enemy Warning - low pulse
    playWarning() {
        if (!this.initialized) this.init();
        this.playTone(200, 0.15, 'sawtooth', 0.15);
        setTimeout(() => this.playTone(180, 0.15, 'sawtooth', 0.15), 120);
    }

    // Victory - celebratory chord
    playVictory() {
        if (!this.initialized) this.init();
        [523.25, 659.25, 783.99, 1046.50].forEach((freq, i) => {
            setTimeout(() => this.playTone(freq, 0.5, 'sine', 0.2), i * 80);
        });
    }

    // Game Over - descending tones
    playGameOver() {
        if (!this.initialized) this.init();
        [400, 350, 300, 200].forEach((freq, i) => {
            setTimeout(() => this.playTone(freq, 0.4, 'sawtooth', 0.2), i * 150);
        });
    }

    // Death Voice effect
    playDeathVoice() {
        if (!this.initialized) this.init();
        this.playTone(150, 0.3, 'sawtooth', 0.25);
        setTimeout(() => this.playTone(100, 0.5, 'sawtooth', 0.2), 200);
    }

    // Level Complete Voice
    playLevelComplete() {
        if (!this.initialized) this.init();
        [600, 800, 1000].forEach((freq, i) => {
            setTimeout(() => this.playTone(freq, 0.2, 'sine', 0.15), i * 100);
        });
    }
}

