// ============================================
// PARTICLE SYSTEM
// ============================================
class ParticleSystem {
    constructor() {
        this.particles = [];
    }

    spawn(x, y, color, count = 8) {
        for (let i = 0; i < count; i++) {
            const angle = (Math.PI * 2 * i) / count;
            const speed = 2 + Math.random() * 3;
            this.particles.push({
                x, y,
                vx: Math.cos(angle) * speed,
                vy: Math.sin(angle) * speed,
                life: 1.0,
                decay: 0.02 + Math.random() * 0.03,
                size: 2 + Math.random() * 3,
                color
            });
        }
    }

    update() {
        for (let i = this.particles.length - 1; i >= 0; i--) {
            const p = this.particles[i];
            p.x += p.vx;
            p.y += p.vy;
            p.life -= p.decay;
            p.size *= 0.98;
            if (p.life <= 0) {
                this.particles.splice(i, 1);
            }
        }
    }

    draw(ctx) {
        this.particles.forEach(p => {
            ctx.globalAlpha = p.life;
            ctx.fillStyle = p.color;
            ctx.beginPath();
            ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
            ctx.fill();
        });
        ctx.globalAlpha = 1;
    }
}

// ============================================
// SNAKE CLASS
// ============================================
class Snake {
    constructor(x, y, length, color, glowColor, isEnemy = false) {
        this.body = [];
        for (let i = 0; i < length; i++) {
            this.body.push({ x: x - i, y });
        }
        this.direction = { x: 1, y: 0 };
        this.nextDirection = { x: 1, y: 0 };
        this.color = color;
        this.glowColor = glowColor;
        this.isEnemy = isEnemy;
        this.trail = [];
        this.maxTrail = isEnemy ? 15 : 20;
        this.alive = true;
    }

    setDirection(dx, dy) {
        // Prevent reversing directly
        if (this.direction.x === -dx && this.direction.y === -dy) return;
        this.nextDirection = { x: dx, y: dy };
    }

    move(gridWidth, gridHeight) {
        if (!this.alive) return;

        this.direction = { ...this.nextDirection };
        const head = { ...this.body[0] };
        head.x += this.direction.x;
        head.y += this.direction.y;

        // Store trail
        this.trail.unshift({ ...this.body[0] });
        if (this.trail.length > this.maxTrail) {
            this.trail.pop();
        }

        this.body.unshift(head);
        this.body.pop();
    }

    grow() {
        const tail = this.body[this.body.length - 1];
        this.body.push({ ...tail });
    }

    checkSelfCollision() {
        const head = this.body[0];
        for (let i = 1; i < this.body.length; i++) {
            if (head.x === this.body[i].x && head.y === this.body[i].y) {
                return true;
            }
        }
        return false;
    }

    checkWallCollision(gridWidth, gridHeight) {
        const head = this.body[0];
        return head.x < 0 || head.x >= gridWidth || head.y < 0 || head.y >= gridHeight;
    }

    checkCollisionWith(otherSnake) {
        const head = this.body[0];
        for (const segment of otherSnake.body) {
            if (head.x === segment.x && head.y === segment.y) {
                return true;
            }
        }
        return false;
    }

    draw(ctx, cellSize) {
        if (!this.alive) return;

        // Draw trail
        this.trail.forEach((pos, i) => {
            const alpha = (1 - i / this.trail.length) * 0.15;
            const size = cellSize * (0.3 + (1 - i / this.trail.length) * 0.4);
            ctx.globalAlpha = alpha;
            ctx.fillStyle = this.glowColor;
            ctx.beginPath();
            ctx.roundRect(
                pos.x * cellSize + (cellSize - size) / 2,
                pos.y * cellSize + (cellSize - size) / 2,
                size, size, size / 4
            );
            ctx.fill();
        });
        ctx.globalAlpha = 1;

        // Draw body segments
        this.body.forEach((segment, i) => {
            const isHead = i === 0;
            const size = isHead ? cellSize * 0.95 : cellSize * 0.85;
            const offset = (cellSize - size) / 2;
            const radius = isHead ? size / 3 : size / 4;

            // Glow effect
            if (isHead) {
                ctx.shadowColor = this.glowColor;
                ctx.shadowBlur = 15;
            } else {
                ctx.shadowColor = this.glowColor;
                ctx.shadowBlur = 5;
            }

            ctx.fillStyle = this.color;
            ctx.beginPath();
            ctx.roundRect(
                segment.x * cellSize + offset,
                segment.y * cellSize + offset,
                size, size, radius
            );
            ctx.fill();

            // Head details
            if (isHead) {
                ctx.fillStyle = 'rgba(255, 255, 255, 0.8)';
                const eyeSize = size * 0.15;
                const eyeOffset = size * 0.25;
                // Eyes
                ctx.beginPath();
                ctx.arc(
                    segment.x * cellSize + offset + eyeOffset,
                    segment.y * cellSize + offset + eyeOffset,
                    eyeSize, 0, Math.PI * 2
                );
                ctx.fill();
                ctx.beginPath();
                ctx.arc(
                    segment.x * cellSize + offset + size - eyeOffset,
                    segment.y * cellSize + offset + eyeOffset,
                    eyeSize, 0, Math.PI * 2
                );
                ctx.fill();
            }

            ctx.shadowBlur = 0;
        });
    }
}

// ============================================
// ENEMY AI
// ============================================
class EnemyAI {
    constructor(enemySnake, playerSnake) {
        this.enemy = enemySnake;
        this.player = playerSnake;
        this.walls = [];
    }

    setWalls(walls) {
        this.walls = walls;
    }

    think(gridWidth, gridHeight) {
        if (!this.enemy.alive || !this.player.alive) return;

        const head = this.enemy.body[0];
        const playerHead = this.player.body[0];

        // Calculate direction to player
        let dx = Math.sign(playerHead.x - head.x);
        let dy = Math.sign(playerHead.y - head.y);

        // Try primary direction
        let bestDir = this.findBestDirection(head, playerHead, gridWidth, gridHeight);
        
        if (bestDir) {
            this.enemy.setDirection(bestDir.x, bestDir.y);
        }
    }

    findBestDirection(head, target, gridW, gridH) {
        const directions = [
            { x: 0, y: -1 }, { x: 0, y: 1 },
            { x: -1, y: 0 }, { x: 1, y: 0 }
        ];

        // Don't reverse
        const currentDir = this.enemy.direction;
        const validDirs = directions.filter(d => 
            !(d.x === -currentDir.x && d.y === -currentDir.y)
        );

        let bestDir = null;
        let bestScore = -Infinity;

        for (const dir of validDirs) {
            const nextX = head.x + dir.x;
            const nextY = head.y + dir.y;

            // Check wall collision
            if (nextX < 0 || nextX >= gridW || nextY < 0 || nextY >= gridH) continue;
            
            // Check wall block collision
            if (this.walls.some(w => w.x === nextX && w.y === nextY)) continue;

            // Check self collision
            if (this.enemy.body.some((seg, i) => i > 0 && seg.x === nextX && seg.y === nextY)) continue;

            // Score based on distance to player
            const distToPlayer = Math.abs(target.x - nextX) + Math.abs(target.y - nextY);
            const score = -distToPlayer;

            if (score > bestScore) {
                bestScore = score;
                bestDir = dir;
            }
        }

        // If no safe direction, try any non-reversing
        if (!bestDir) {
            for (const dir of validDirs) {
                const nextX = head.x + dir.x;
                const nextY = head.y + dir.y;
                if (nextX >= 0 && nextX < gridW && nextY >= 0 && nextY < gridH) {
                    return dir;
                }
            }
        }

        return bestDir;
    }
}

