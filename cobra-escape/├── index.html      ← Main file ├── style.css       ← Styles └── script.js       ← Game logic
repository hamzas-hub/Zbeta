// INPUT HANDLING
// ============================================
function setupControls() {
    // D-Pad buttons
    const btnUp = document.getElementById('btn-up');
    const btnDown = document.getElementById('btn-down');
    const btnLeft = document.getElementById('btn-left');
    const btnRight = document.getElementById('btn-right');

    const handleDir = (dx, dy) => {
        if (gameEngine.gameState === 'playing' && gameEngine.player) {
            gameEngine.player.setDirection(dx, dy);
        }
    };

    // Touch events for D-pad
    const addTouch = (btn, dx, dy) => {
        btn.addEventListener('touchstart', (e) => {
            e.preventDefault();
            handleDir(dx, dy);
            btn.style.transform = 'scale(0.9)';
            btn.style.background = 'rgba(0, 255, 65, 0.2)';
        }, { passive: false });
        
        btn.addEventListener('touchend', (e) => {
            e.preventDefault();
            btn.style.transform = '';
            btn.style.background = '';
        });
        
        btn.addEventListener('mousedown', (e) => {
            handleDir(dx, dy);
        });
    };

    addTouch(btnUp, 0, -1);
    addTouch(btnDown, 0, 1);
    addTouch(btnLeft, -1, 0);
    addTouch(btnRight, 1, 0);

    // Keyboard controls (for desktop testing)
    document.addEventListener('keydown', (e) => {
        if (gameEngine.gameState !== 'playing') return;
        switch(e.key) {
            case 'ArrowUp': case 'w': case 'W':
                gameEngine.player.setDirection(0, -1); break;
            case 'ArrowDown': case 's': case 'S':
                gameEngine.player.setDirection(0, 1); break;
            case 'ArrowLeft': case 'a': case 'A':
                gameEngine.player.setDirection(-1, 0); break;
            case 'ArrowRight': case 'd': case 'D':
                gameEngine.player.setDirection(1, 0); break;
            case ' ':
                e.preventDefault();
                gameEngine.pause(); break;
        }
    });

    // Swipe controls for mobile
    let touchStartX = 0;
    let touchStartY = 0;
    
    document.getElementById('game-canvas').addEventListener('touchstart', (e) => {
        touchStartX = e.touches[0].clientX;
        touchStartY = e.touches[0].clientY;
    }, { passive: true });
    
    document.getElementById('game-canvas').addEventListener('touchend', (e) => {
        if (!touchStartX || !touchStartY) return;
        const dx = e.changedTouches[0].clientX - touchStartX;
        const dy = e.changedTouches[0].clientY - touchStartY;
        const minSwipe = 30;
        
        if (Math.abs(dx) > Math.abs(dy)) {
            if (Math.abs(dx) > minSwipe) {
                handleDir(dx > 0 ? 1 : -1, 0);
            }
        } else {
            if (Math.abs(dy) > minSwipe) {
                handleDir(0, dy > 0 ? 1 : -1);
            }
        }
        touchStartX = 0;
        touchStartY = 0;
    }, { passive: true });
}

