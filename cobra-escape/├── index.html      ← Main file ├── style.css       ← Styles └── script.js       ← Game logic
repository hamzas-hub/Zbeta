css_content = '''/* ============================================
   COBRA ESCAPE - Premium Snake Survival Game
   Mobile-First CSS
   ============================================ */

/* ===== CSS Variables ===== */
:root {
    --neon-green: #00ff41;
    --neon-green-dim: #00cc33;
    --neon-red: #ff0040;
    --neon-orange: #ff6600;
    --neon-yellow: #ffcc00;
    --dark-bg: #0a0a0a;
    --darker-bg: #050505;
    --panel-bg: rgba(10, 20, 10, 0.85);
    --glass: rgba(0, 255, 65, 0.08);
    --glow-green: 0 0 20px rgba(0, 255, 65, 0.6), 0 0 40px rgba(0, 255, 65, 0.3);
    --glow-red: 0 0 20px rgba(255, 0, 64, 0.6), 0 0 40px rgba(255, 0, 64, 0.3);
    --glow-orange: 0 0 20px rgba(255, 102, 0, 0.6), 0 0 40px rgba(255, 102, 0, 0.3);
    --transition-smooth: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

/* ===== Reset & Base ===== */
*, *::before, *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    -webkit-tap-highlight-color: transparent;
    touch-action: manipulation;
}

html, body {
    width: 100%;
    height: 100%;
    overflow: hidden;
    background: var(--darker-bg);
    font-family: 'Segoe UI', 'Roboto', 'Helvetica Neue', sans-serif;
    color: #fff;
    user-select: none;
    -webkit-user-select: none;
}

/* ===== Screen Management ===== */
.screen {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: none;
    opacity: 0;
    transition: opacity 0.6s ease;
    z-index: 1;
}

.screen.active {
    display: flex;
    opacity: 1;
    z-index: 10;
}

/* ===== Loading Screen ===== */
#loading-screen {
    background: var(--darker-bg);
    justify-content: center;
    align-items: center;
    flex-direction: column;
    z-index: 100;
}

.loading-container {
    text-align: center;
    animation: fadeIn 0.5s ease;
}

.loading-cobra {
    width: 80px;
    height: 80px;
    margin: 0 auto 24px;
    border: 3px solid var(--neon-green);
    border-radius: 50%;
    border-top-color: transparent;
    animation: spin 1s linear infinite, pulse-glow 1.5s ease infinite;
    box-shadow: var(--glow-green);
}

.loading-cobra::after {
    content: '';
    position: absolute;
    top: 8px;
    left: 8px;
    right: 8px;
    bottom: 8px;
    border: 2px solid var(--neon-green-dim);
    border-radius: 50%;
    border-bottom-color: transparent;
    animation: spin 1.5s linear infinite reverse;
}

.loading-text {
    font-size: 14px;
    letter-spacing: 8px;
    color: var(--neon-green);
    text-shadow: var(--glow-green);
    margin-bottom: 20px;
    animation: pulse-text 1.5s ease infinite;
}

.loading-bar {
    width: 200px;
    height: 3px;
    background: rgba(0, 255, 65, 0.1);
    border-radius: 3px;
    overflow: hidden;
    margin: 0 auto;
}

.loading-progress {
    width: 0%;
    height: 100%;
    background: linear-gradient(90deg, var(--neon-green), var(--neon-green-dim));
    border-radius: 3px;
    animation: loadProgress 2s ease forwards;
    box-shadow: var(--glow-green);
}

/* ===== Home Screen ===== */
#home-screen {
    justify-content: center;
    align-items: center;
    flex-direction: column;
    overflow: hidden;
}

.home-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
    background: radial-gradient(ellipse at center, #1a0a00 0%, #0a0000 60%, #000 100%);
}

/* Animated gradient orbs */
.gradient-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.4;
    animation: orbFloat 8s ease-in-out infinite;
}

.orb-1 {
    width: 300px;
    height: 300px;
    background: var(--neon-orange);
    top: -100px;
    left: -50px;
    animation-delay: 0s;
}

.orb-2 {
    width: 250px;
    height: 250px;
    background: var(--neon-red);
    bottom: -80px;
    right: -40px;
    animation-delay: -2s;
}

.orb-3 {
    width: 200px;
    height: 200px;
    background: var(--neon-green);
    top: 40%;
    left: 60%;
    opacity: 0.15;
    animation-delay: -4s;
}

.orb-4 {
    width: 350px;
    height: 350px;
    background: #330000;
    bottom: 20%;
    left: 20%;
    opacity: 0.3;
    animation-delay: -6s;
}

/* Cobra background image */
.cobra-bg {
    position: absolute;
    inset: 0;
    background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 400 400"><defs><radialGradient id="eye" cx="50%" cy="50%"><stop offset="0%" stop-color="%23ff0000"/><stop offset="100%" stop-color="%23880000"/></radialGradient></defs><ellipse cx="200" cy="200" rx="120" ry="100" fill="%23222" opacity="0.3"/><ellipse cx="160" cy="180" rx="25" ry="30" fill="url(%23eye)"/><ellipse cx="240" cy="180" rx="25" ry="30" fill="url(%23eye)"/><ellipse cx="160" cy="180" rx="10" ry="15" fill="%23000"/><ellipse cx="240" cy="180" rx="10" ry="15" fill="%23000"/><path d="M200 220 Q200 260 180 280" stroke="%23444" stroke-width="3" fill="none"/><path d="M200 220 Q200 260 220 280" stroke="%23444" stroke-width="3" fill="none"/><path d="M140 250 Q120 270 100 260" stroke="%23444" stroke-width="2" fill="none"/><path d="M260 250 Q280 270 300 260" stroke="%23444" stroke-width="2" fill="none"/><path d="M200 120 Q200 80 220 60" stroke="%23333" stroke-width="4" fill="none"/><circle cx="220" cy="55" r="8" fill="%23ff6600" opacity="0.6"/></svg>') center/contain no-repeat;
    opacity: 0.05;
    transform: scale(1.2);
    animation: cobraBreath 6s ease-in-out infinite;
}

.home-content {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: 20px;
    animation: fadeInUp 1s ease 0.5s both;
}

.logo-container {
    position: relative;
    margin-bottom: 12px;
}

.game-title {
    font-size: clamp(48px, 12vw, 80px);
    font-weight: 900;
    letter-spacing: 12px;
    color: var(--neon-green);
    text-shadow: 
        0 0 10px rgba(0, 255, 65, 0.8),
        0 0 30px rgba(0, 255, 65, 0.5),
        0 0 60px rgba(0, 255, 65, 0.3);
    line-height: 1;
    animation: titlePulse 3s ease-in-out infinite;
}

.game-subtitle {
    font-size: clamp(24px, 6vw, 40px);
    font-weight: 300;
