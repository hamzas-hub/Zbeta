        const cols = 25;
        const rows = 20;
        const cellSize = Math.min(Math.floor(maxW / cols), Math.floor(maxH / rows));
        
        this.canvas.width = cols * cellSize;
        this.canvas.height = rows * cellSize;
        this.canvas.style.width = this.canvas.width + 'px';
        this.canvas.style.height = this.canvas.height + 'px';
        
        GAME_CONFIG.cellSize = cellSize;
        this.gridWidth = cols;
        this.gridHeight = rows;
    }

    initLevel(levelNum) {
        const level = GAME_CONFIG.levels[levelNum - 1];
        if (!level) return;

        this.currentLevel = levelNum;
        this.targetTime = level.target;
        this.tickRate = level.enemySpeed;
        
        // Create player snake (green, center-left)
        this.player = new Snake(
            Math.floor(this.gridWidth * 0.3),
            Math.floor(this.gridHeight / 2),
            5,
            '#00ff41',
            'rgba(0, 255, 65, 0.8)',
            false
        );
        this.player.setDirection(1, 0);

        // Create enemy snake (red, center-right)
        this.enemy = new Snake(
            Math.floor(this.gridWidth * 0.7),
            Math.floor(this.gridHeight / 2),
            level.enemySize,
            '#ff0040',
            'rgba(255, 0, 64, 0.8)',
            true
        );
        this.enemy.setDirection(-1, 0);

        this.enemyAI = new EnemyAI(this.enemy, this.player);

        // Generate walls
        this.generateWalls(level.wallCount);
        this.enemyAI.setWalls(this.walls);

        // Reset state
        this.gameState = 'playing';
        this.startTime = Date.now();
        this.elapsedTime = 0;
        this.warningPlayed = false;
        this.particles = new ParticleSystem();

        // Update UI
        this.updateUI();
        document.getElementById('target-time').textContent = this.formatTime(this.targetTime);
        document.getElementById('current-level').textContent = levelNum;
        
        // Start game loop
        this.lastFrame = performance.now();
        this.accumulator = 0;
        if (this.animationId) cancelAnimationFrame(this.animationId);
        this.gameLoop();
        
        this.audio.playGameStart();
    }

    generateWalls(count) {
        this.walls = [];
        const margin = 3; // Keep away from edges and spawn areas
        
        for (let i = 0; i < count; i++) {
            let x, y, valid;
            let attempts = 0;
            do {
                valid = true;
                x = margin + Math.floor(Math.random() * (this.gridWidth - margin * 2));
                y = margin + Math.floor(Math.random() * (this.gridHeight - margin * 2));
                
                // Don't spawn near player or enemy
                const distToPlayer = Math.abs(x - this.player.body[0].x) + Math.abs(y - this.player.body[0].y);
                const distToEnemy = Math.abs(x - this.enemy.body[0].x) + Math.abs(y - this.enemy.body[0].y);
                
                if (distToPlayer < 5 || distToEnemy < 5) valid = false;
                
                // Don't overlap existing walls
                if (this.walls.some(w => w.x === x && w.y === y)) valid = false;
                
                attempts++;
            } while (!valid && attempts < 50);
            
            if (valid) {
                this.walls.push({ x, y });
            }
        }
    }

    gameLoop() {
        if (this.gameState === 'idle') return;

        const now = performance.now();
        const delta = now - this.lastFrame;
        this.lastFrame = now;

        if (this.gameState === 'playing') {
            this.accumulator += delta;
            
            // Update timer
            this.elapsedTime = Math.floor((Date.now() - this.startTime) / 1000);
            
            // Check warning
            const distToEnemy = this.getDistanceToEnemy();
            if (distToEnemy < 5 && !this.warningPlayed) {
                this.audio.playWarning();
                this.warningPlayed = true;
            } else if (distToEnemy >= 7) {
                this.warningPlayed = false;
            }

            // Game tick
            while (this.accumulator >= this.tickRate) {
                this.update();
                this.accumulator -= this.tickRate;
            }

            // Check victory
            if (this.elapsedTime >= this.targetTime) {
                this.victory();
                return;
            }
        }

        this.render();
        this.updateUI();
        
        this.animationId = requestAnimationFrame(() => this.gameLoop());
    }

    update() {
        // Enemy AI thinks
        this.enemyAI.think(this.gridWidth, this.gridHeight);

        // Move snakes
        this.player.move(this.gridWidth, this.gridHeight);
        this.enemy.move(this.gridWidth, this.gridHeight);

        // Check collisions
        this.checkCollisions();

        // Update particles
        this.particles.update();
    }

    checkCollisions() {
        const pHead = this.player.body[0];
        const eHead = this.enemy.body[0];

        // Player wall collision
        if (this.player.checkWallCollision(this.gridWidth, this.gridHeight)) {
            this.gameOver('You hit the wall!');
            return;
        }

        // Player self collision
        if (this.player.checkSelfCollision()) {
            this.gameOver('You crashed into yourself!');
            return;
        }

        // Enemy wall collision
        if (this.enemy.checkWallCollision(this.gridWidth, this.gridHeight)) {
            this.gameOver('Enemy hit wall! You win!');
            return;
        }

        // Enemy self collision
        if (this.enemy.checkSelfCollision()) {
            this.gameOver('Enemy crashed! You win!');
            return;
        }

        // Wall collision for both
        for (const wall of this.walls) {
            if (pHead.x === wall.x && pHead.y === wall.y) {
                this.gameOver('You hit a wall block!');
                return;
            }
            if (eHead.x === wall.x && eHead.y === wall.y) {
                this.gameOver('Enemy hit wall! You win!');
                return;
            }
        }

        // Snake-to-snake collision
        if (this.player.checkCollisionWith(this.enemy)) {
            this.gameOver('The cobra caught you!');
            return;
        }
        if (this.enemy.checkCollisionWith(this.player)) {
            this.gameOver('The cobra caught you!');
            return;
        }
    }

    getDistanceToEnemy() {
        const pHead = this.player.body[0];
        const eHead = this.enemy.body[0];
        return Math.abs(pHead.x - eHead.x) + Math.abs(pHead.y - eHead.y);
    }

    render() {
        const ctx = this.ctx;
        const cs = GAME_CONFIG.cellSize;
        const w = this.canvas.width;
        const h = this.canvas.height;

        // Clear with dark background
        ctx.fillStyle = '#0a0a0a';
        ctx.fillRect(0, 0, w, h);

        // Draw grid lines (subtle)
        ctx.strokeStyle = 'rgba(0, 255, 65, 0.03)';
        ctx.lineWidth = 1;
        for (let x = 0; x <= this.gridWidth; x++) {
            ctx.beginPath();
            ctx.moveTo(x * cs, 0);
            ctx.lineTo(x * cs, h);
            ctx.stroke();
        }
        for (let y = 0; y <= this.gridHeight; y++) {
            ctx.beginPath();
            ctx.moveTo(0, y * cs);
            ctx.lineTo(w, y * cs);
            ctx.stroke();
        }

        // Draw walls
        ctx.fillStyle = '#333';
        ctx.shadowColor = 'rgba(255, 100, 0, 0.3)';
        ctx.shadowBlur = 5;
        this.walls.forEach(wall => {
            const pad = cs * 0.1;
            ctx.fillRect(
                wall.x * cs + pad,
                wall.y * cs + pad,
                cs - pad * 2,
                cs - pad * 2
            );
            // Wall highlight
            ctx.fillStyle = 'rgba(255, 100, 0, 0.3)';
            ctx.fillRect(
                wall.x * cs + pad + 2,
                wall.y * cs + pad + 2,
                cs - pad * 2 - 4,
                2
            );
            ctx.fillStyle = '#333';
        });
        ctx.shadowBlur = 0;

        // Draw particles
        this.particles.draw(ctx);

        // Draw snakes
        if (this.enemy) this.enemy.draw(ctx, cs);
        if (this.player) this.player.draw(ctx, cs);

        // Draw danger indicator when enemy is close
        const dist = this.getDistanceToEnemy();
        if (dist < 8) {
            const alpha = (8 - dist) / 8 * 0.15;
            ctx.fillStyle = `rgba(255, 0, 64, ${alpha})`;
            ctx.fillRect(0, 0, w, h);
        }
    }

    updateUI() {
        document.getElementById('timer').textContent = this.formatTime(this.elapsedTime);
        document.getElementById('high-score').textContent = this.highScore;
    }

    formatTime(seconds) {
        const m = Math.floor(seconds / 60).toString().padStart(2, '0');
        const s = (seconds % 60).toString().padStart(2, '0');
        return `${m}:${s}`;
    }

    pause() {
        if (this.gameState === 'playing') {
            this.gameState = 'paused';
            document.getElementById('pause-overlay').classList.add('active');
        }
    }

    resume() {
        if (this.gameState === 'paused') {
            this.gameState = 'playing';
            this.startTime = Date.now() - this.elapsedTime * 1000;
            document.getElementById('pause-overlay').classList.remove('active');
            this.lastFrame = performance.now();
        }
    }

    gameOver(reason) {
        this.gameState = 'gameover';
        this.player.alive = false;
        
        // Spawn death particles
        const cs = GAME_CONFIG.cellSize;
        const head = this.player.body[0];
        this.particles.spawn(
            head.x * cs + cs / 2,
            head.y * cs + cs / 2,
            '#00ff41',
            20
        );
        
        // Vibration
        if (navigator.vibrate) navigator.vibrate([100, 50, 100]);
        
        // Audio
        this.audio.playDeathVoice();
        setTimeout(() => this.audio.playGameOver(), 300);
        
        // Update high score
        if (this.elapsedTime > this.highScore) {
            this.highScore = this.elapsedTime;
            StorageManager.setHighScore(this.highScore);
        }
        
        // Show overlay
        setTimeout(() => {
            document.getElementById('go-time').textContent = this.formatTime(this.elapsedTime);
            document.getElementById('go-level').textContent = this.currentLevel;
            document.getElementById('gameover-overlay').classList.add('active');
        }, 800);
    }

    victory() {
        this.gameState = 'victory';
        
        // Spawn victory particles
        const cs = GAME_CONFIG.cellSize;
        for (let i = 0; i < 5; i++) {
            setTimeout(() => {
                this.particles.spawn(
                    Math.random() * this.canvas.width,
                    Math.random() * this.canvas.height,
                    '#00ff41',
                    15
                );
            }, i * 200);
        }
        
        // Vibration
        if (navigator.vibrate) navigator.vibrate([50, 50, 50, 50, 100]);
        
        // Audio
        this.audio.playLevelComplete();
        setTimeout(() => this.audio.playVictory(), 400);
        
        // Save progress
        StorageManager.addCompletedLevel(this.currentLevel);
        const nextLevel = this.currentLevel + 1;
        if (nextLevel <= 10) {
            const currentUnlocked = StorageManager.getUnlockedLevel();
            if (nextLevel > currentUnlocked) {
                StorageManager.setUnlockedLevel(nextLevel);
            }
        }
        
        // Update high score
        if (this.elapsedTime > this.highScore) {
            this.highScore = this.elapsedTime;
            StorageManager.setHighScore(this.highScore);
        }
        
        // Show overlay
        setTimeout(() => {
            document.getElementById('vic-time').textContent = this.formatTime(this.elapsedTime);
            document.getElementById('vic-next').textContent = Math.min(nextLevel, 10);
            document.getElementById('victory-overlay').classList.add('active');
        }, 1000);
    }

    cleanup() {
        if (this.animationId) {
            cancelAnimationFrame(this.animationId);
            this.animationId = null;
        }
        this.gameState = 'idle';
    }
}

// ============================================
// SCREEN MANAGER
// ============================================
class ScreenManager {
    constructor() {
        this.screens = {
            loading: document.getElementById('loading-screen'),
            home: document.getElementById('home-screen'),
            menu: document.getElementById('menu-screen'),
            levels: document.getElementById('levels-screen'),
            game: document.getElementById('game-screen')
        };
        this.current = 'loading';
        this.audio = new AudioSystem();
    }

    show(screenName) {
        // Hide all
        Object.values(this.screens).forEach(s => {
            s.classList.remove('active');
        });
        
        // Show target
        const target = this.screens[screenName];
        if (target) {
            target.classList.add('active');
            this.current = screenName;
        }
        
        // Play transition sound
        this.audio.playClick();
    }

    transition(from, to, delay = 400) {
        this.screens[from].style.opacity = '0';
        setTimeout(() => {
            this.screens[from].classList.remove('active');
            this.screens[from].style.opacity = '';
            this.show(to);
        }, delay);
    }
}

// ============================================
// LEVELS UI BUILDER
// ============================================
function buildLevelsGrid() {
    const grid = document.getElementById('levels-grid');
    const unlocked = StorageManager.getUnlockedLevel();
    const completed = StorageManager.getCompletedLevels();
    
    grid.innerHTML = '';
    
    GAME_CONFIG.levels.forEach(level => {
        const card = document.createElement('div');
        card.className = 'level-card';
        
        if (level.num > unlocked) {
            card.classList.add('locked');
        } else if (completed.includes(level.num)) {
            card.classList.add('completed');
        }
        
        const diffClass = level.diff.toLowerCase();
        const targetMins = Math.floor(level.target / 60);
        
        card.innerHTML = `
            <div class="level-num">${level.num}</div>
            <div class="level-diff ${diffClass}">${level.diff}</div>
            <div class="level-target">${targetMins} min</div>
        `;
        
        card.addEventListener('click', () => {
            if (level.num <= unlocked) {
                gameEngine.audio.playClick();
                screenManager.show('game');
                gameEngine.initLevel(level.num);
            }
        });
        
        grid.appendChild(card);
    });
}

