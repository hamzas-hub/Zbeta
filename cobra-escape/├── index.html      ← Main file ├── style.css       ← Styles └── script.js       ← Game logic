    color: var(--neon-orange);
    text-shadow: 
        0 0 10px rgba(255, 102, 0, 0.6),
        0 0 30px rgba(255, 102, 0, 0.3);
    margin-top: -5px;
}

.title-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 300px;
    height: 100px;
    background: radial-gradient(ellipse, rgba(0, 255, 65, 0.15), transparent 70%);
    filter: blur(20px);
    animation: glowPulse 3s ease-in-out infinite;
}

.tagline {
    font-size: 14px;
    letter-spacing: 6px;
    color: rgba(255, 255, 255, 0.4);
    margin-bottom: 48px;
    text-transform: uppercase;
}

/* ===== Glow Button ===== */
.glow-btn {
    position: relative;
    background: transparent;
    border: 2px solid var(--neon-green);
    color: var(--neon-green);
    padding: 16px 40px;
    font-size: 16px;
    font-weight: 600;
    letter-spacing: 3px;
    text-transform: uppercase;
    cursor: pointer;
    border-radius: 50px;
    overflow: hidden;
    transition: var(--transition-smooth);
    box-shadow: var(--glow-green);
    backdrop-filter: blur(10px);
}

.glow-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(0, 255, 65, 0.1), rgba(0, 255, 65, 0.05));
    opacity: 0;
    transition: opacity 0.3s ease;
}

.glow-btn:hover::before,
.glow-btn:active::before {
    opacity: 1;
}

.glow-btn:hover,
.glow-btn:active {
    transform: translateY(-2px);
    box-shadow: 
        0 0 30px rgba(0, 255, 65, 0.8),
        0 0 60px rgba(0, 255, 65, 0.4),
        inset 0 0 20px rgba(0, 255, 65, 0.1);
    text-shadow: 0 0 10px rgba(0, 255, 65, 0.8);
}

.main-btn {
    font-size: clamp(14px, 4vw, 18px);
